# ─── Backend .env ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas — leave placeholder values for local in-memory mode (no MongoDB needed)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gate2027?retryWrites=true&w=majority

# Force local in-memory auth (optional; also auto-enabled when MONGO_URI has placeholders)
USE_MOCK_AUTH=true

# JWT Secrets (use long random strings)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email (SendGrid or any SMTP) — leave SMTP_PASS as placeholder for dev; links log to console
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
FROM_EMAIL=noreply@gate2027.in

# OpenAI / OpenRouter / DashScope (optional — enables AI Mentor and study planner)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Live data cron (for external cron hitting /api/cron/fetch-live-data)
CRON_SECRET=your_cron_secret_min_32_chars

# Google OAuth (Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Frontend .env (Vite) ────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=GATE 2027 Tracker
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Firebase Cloud Messaging (optional — real push notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
