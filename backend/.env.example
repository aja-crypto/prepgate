# ─── GateNexa Backend - Environment Variables ────────────────────────────────
# Copy this to Render as environment variables. Do NOT commit real values.

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/gate2027?retryWrites=true&w=majority

# ─── Authentication ──────────────────────────────────────────────────────────
JWT_SECRET=<generate-64-char-hex>
JWT_REFRESH_SECRET=<generate-64-char-hex>
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
USE_MOCK_AUTH=false

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=https://gatenexa.in,https://www.gatenexa.in,https://gatenexa.vercel.app
FRONTEND_URL=https://gatenexa.in
BACKEND_URL=https://gatenexa-api.onrender.com

# ─── AI (OpenRouter) ────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# ─── Cloudinary (PDF storage + secure viewer) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=...
FROM_EMAIL=noreply@gatenexa.in

# ─── Cron Secret ─────────────────────────────────────────────────────────────
CRON_SECRET=<generate-random-hex>

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
